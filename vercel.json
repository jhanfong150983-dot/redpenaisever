{
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 300
    }
  },
  "env": {
    "NODE_OPTIONS": "--no-deprecation"
  },
  "rewrites": [
    {
      "source": "/api/auth/1campus-oauth-callback",
      "destination": "/api/auth/1campus?__step=oauth_callback"
    },
    {
      "source": "/api/oauth/callback",
      "destination": "/api/auth/1campus?__step=oauth_callback"
    }
  ],
  "crons": [
    {
      "path": "/api/admin/aggregate-tags",
      "schedule": "0 18 * * *"
    }
  ]
}
