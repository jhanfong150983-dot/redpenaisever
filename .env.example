SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SITE_URL=https://app.your-domain.com
FRONTEND_URL=https://app.your-domain.com
BACKEND_URL=https://api.your-domain.com

SECRET_API_KEY=your_gemini_api_key_here
SYSTEM_GEMINI_API_KEY=

ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_ENV=stage
ECPAY_CHOOSE_PAYMENT=Credit
# ECPAY_BASE_URL=https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5
# ECPAY_TRADE_DESC=RedPen AI 墨水補充

# 1Campus SSO + OAuth（Phase 2 班級同步）
# 向廠商申請後填入
CAMPUS1_CLIENT_ID=
CAMPUS1_CLIENT_SECRET=
# OAuth callback URL（需在廠商後台白名單登記）
# 本機開發：http://localhost:3000/api/auth/1campus-oauth-callback
# 正式環境：https://api.your-domain.com/api/auth/1campus-oauth-callback
CAMPUS1_OAUTH_CALLBACK=
# 可選：覆寫 API base（預設使用正式站）
# CAMPUS1_IDENTITY_API_BASE=https://api.1campus.net
# CAMPUS1_JASMINE_API_BASE=https://api.1campus.net/api/jasmine

# Optional auth/cors settings for split frontend/backend deployment
# AUTH_COOKIE_DOMAIN=.your-domain.com
# AUTH_COOKIE_SAME_SITE=Lax
# CORS_ORIGINS=https://app.your-domain.com
# CRON_SECRET=your_cron_secret

# Grading pipeline mode: auto | staged | single
# AI_GRADING_PIPELINE_MODE=auto

# ReadAnswer split mode override (staged only): true/on/1 or false/off/0
# READ_ANSWER_SPLIT_MODE=on

# Gemini 504 retry settings (server-side)
# retry count means "additional retries after first attempt" (default: 3)
# GEMINI_504_RETRY_COUNT=3
# GEMINI_504_RETRY_BACKOFF_MS=800
